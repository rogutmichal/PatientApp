<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PatientApp.Views.SugarPage"
             BackgroundColor="MistyRose"
             Title="Cukier"
             >

    <StackLayout Margin="20,35,20,20" BackgroundColor="MistyRose">




        <Button Text="Dodaj pomiar"
            Clicked="OnButtonClicked" BackgroundColor="Coral"/>

        <StackLayout Margin="0,0,0,0">
            <StackLayout Orientation="Horizontal">
                <Button Text="Szczegóły"
            Clicked="OnDetailButtonClicked" BackgroundColor="Coral" HeightRequest="50" WidthRequest="160"  Margin="0,0,0,0" />
                <Button Text="Usuń pomiar"
            Clicked="OnDeleteButtonClicked" BackgroundColor="Coral" HeightRequest="50" WidthRequest="160" Margin="20,0,0,0"/>
            </StackLayout>

            
        </StackLayout>


        <StackLayout BackgroundColor="IndianRed">
            <StackLayout Orientation="Horizontal">



                <Label Text="data"
                               FontAttributes="Bold"
                               FontSize="Medium"/>
                <Label Text="cukier" 
                                   FontAttributes="Bold"
                               FontSize="Medium"
                       Margin="150,0,0,0"
                       />

            </StackLayout>

        </StackLayout>


        <CollectionView x:Name="collectionView"  SelectionMode="Single" SelectedItem="EvetClicked">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">

                            <Label Text="{Binding sugar_id}" IsVisible="false"
                               TextColor="Silver"
                               FontSize="Medium"/>


                            <Label Text="{Binding sugar_date}"
                               TextColor="Silver"
                               FontSize="Medium"/>


                            <Label Text="    "
                               />

                            <Label Text="{Binding sugar}" 
                                FontAttributes="Bold"
                                FontSize="Small"/>
                          

                            <Label Text="{Binding sugar_info }" 
                                FontAttributes="Bold"
                                FontSize="Small"/>



                        </StackLayout>
                        <BoxView HeightRequest="1"
                   BackgroundColor="Black"
                   Grid.Column="2"
                  

                   Grid.Row="2"
                   VerticalOptions="End"/>
                    </StackLayout>

                </DataTemplate>

            </CollectionView.ItemTemplate>
        </CollectionView>


    </StackLayout>


</ContentPage>
