<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="MistyRose"
             x:Class="PatientApp.Views.AboutPage">
            
    <StackLayout Margin="20,35,20,20">
        <Label>Aplikacja medyczna dla pacjentów - Test </Label>
        <Image Source="app_icon.jpg" />
        <Label>Twoje najbliższe wizyty lekarskie</Label>
        <CollectionView x:Name="collectionView"  SelectionMode="Single" SelectedItem="EvetClicked">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">

                            <Label Text="{Binding Subject}" IsVisible="true"
                               TextColor="Black"
                               FontSize="Large"/>

                            <Label Text="{Binding StartTime}" 
                                
                                FontAttributes="Bold"
                                FontSize="Large"

                                   />
                        

                      


                        </StackLayout>
                        <BoxView HeightRequest="1"
                   BackgroundColor="Black"
                   Grid.Column="2"
                  

                   Grid.Row="2"
                   VerticalOptions="End"/>
                    </StackLayout>

                </DataTemplate>

            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text ="Przejdź do kalendarza"  Clicked="Button_Clicked" BackgroundColor="Coral" HeightRequest="50" WidthRequest="160"  Margin="0,0,0,0" />
        
    </StackLayout>


</ContentPage>
