<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PatientApp.Views.MeasurementPage"
             BackgroundColor="MistyRose"
             Title="Inne pomiary"
             >

    <StackLayout Margin="20,35,20,20" BackgroundColor="MistyRose">




        <Button Text="Dodaj pomiar"
            Clicked="OnButtonClicked" BackgroundColor="Coral"/>

        <StackLayout Margin="0,0,0,0">
            <StackLayout Orientation="Horizontal">
                <Button Text="Szczegóły"
            Clicked="OnDetailButtonClicked" BackgroundColor="Coral" HeightRequest="50" WidthRequest="160"  Margin="0,0,0,0" />
                <Button Text="Usuń pomiar"
            Clicked="OnDeleteButtonClicked" BackgroundColor="Coral" HeightRequest="50" WidthRequest="160" Margin="20,0,0,0"/>
            </StackLayout>


        </StackLayout>
        <StackLayout BackgroundColor="IndianRed">
            <StackLayout Orientation="Horizontal">



                <Label Text="data"
                               FontAttributes="Bold"
                               FontSize="Small"/>

                <Label Text="wzrost(cm)" 
                                   FontAttributes="Bold"
                               FontSize="Small"
                                              Margin="40, 0, 0 ,0"

                       />


                <Label Text="waga(kg)" 
                               FontAttributes="Bold"
                               FontSize="Small"
                               Margin="40, 0, 0 ,0"

                       />

             

                <Label Text="bmi" 
                                   FontAttributes="Bold"
                               FontSize="Small"
                       Margin="40, 0, 0 ,0"
                       />
            </StackLayout>
        </StackLayout>

        <CollectionView x:Name="collectionView"  SelectionMode="Single">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout>
                        <StackLayout Orientation="Horizontal">

                            <Label Text="{Binding meas_id}" IsVisible="false"
                               TextColor="Silver"
                               FontSize="Medium"/>

                            <DatePicker Date="{Binding meas_date}"
                                        IsEnabled="False"
                                        FontSize="Small"
                                        TextColor="Black"
                                        FontAttributes="Bold"
                                        >

                            </DatePicker>
                            <Label Text="{Binding height}" 
                                
                                FontAttributes="Bold"
                                FontSize="Small"
                                Margin="0,10,0,0"

                                   />
                            <Label Text="{Binding weight }" 
                                FontAttributes="Bold"
                                FontSize="Small"
                                Margin="80,10,0,0"

                                   />
                            <Label Text="{Binding bmi }" 
                                FontSize="Small"
                                  Margin="90,10,0,0"
                                   />

                            <Label Text="{Binding meas_info }" 
                                FontSize="Small"
                                   Margin="50,10,0,0"
                                   IsVisible="false"
                                   />



                        </StackLayout>
                        <BoxView HeightRequest="1"
                   BackgroundColor="Black"
                   Grid.Column="2"
                  

                   Grid.Row="2"
                   VerticalOptions="End"/>
                    </StackLayout>

                </DataTemplate>

            </CollectionView.ItemTemplate>
        </CollectionView>








    </StackLayout>


</ContentPage>
