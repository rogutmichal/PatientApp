<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PatientApp.Views.NewTempPage"
             Shell.PresentationMode="ModalAnimated"
             Title="Nowy pomiar temperatury"
             BackgroundColor="MistyRose"
             xmlns:ios="clr-namespace:Xamarin.Forms.PlatformConfiguration.iOSSpecific;assembly=Xamarin.Forms.Core"
             ios:Page.UseSafeArea="true">
    <ContentPage.Content>
        <StackLayout Spacing="3" Padding="15">
            <Entry x:Name="temperatureEntry"
                        Placeholder="Wprowadź pomiar" />
            <DatePicker x:Name="tempDataPicker"
                         />
            <TimePicker x:Name="tempTimePicker"
                         />

            <StackLayout Orientation="Horizontal">
                <Button Text="Anuluj" Clicked="OnCancelButtonClicked" BackgroundColor="Coral" HorizontalOptions="FillAndExpand"></Button>
                <Button Text="Dodaj"   Clicked="OnSaveButtonClicked" BackgroundColor="Coral" HorizontalOptions="FillAndExpand"></Button>
            </StackLayout>
        </StackLayout>
    </ContentPage.Content>
    
</ContentPage>
